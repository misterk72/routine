      "targets": [
        {
          "datasource": "MariaDB-Dev",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  CONVERT_TZ(w.start_time, 'Europe/Paris', 'UTC') AS 'Date et Heure',\n  w.program AS 'Programme',\n  w.duration_minutes AS 'Duree (min)',\n  w.avg_speed_kmh AS 'Vitesse Moyenne (km/h)',\n  w.distance_km AS 'Distance parcourue (km)',\n  w.calories AS 'Calories',\n  w.calories_per_km AS 'Calories/km',\n  w.avg_heart_rate AS 'Moyenne pulsations/min',\n  w.max_heart_rate AS 'Max pulsations/min',\n  w.min_heart_rate AS 'Min pulsations/min',\n  w.sleep_heart_rate_avg AS 'FC Repos pulsations/min',\n  w.vo2_max AS 'VO2',\n  wm.weight_kg AS 'Masse (kg)',\n  wm.fat_mass_kg AS 'Masse graisseuse (kg)',\n  wm.fat_percentage AS 'Taux de graisse',\n  wm.waist_cm AS 'Tour de taille (cm)',\n  wm.source_name AS 'Source poids',\n  w.soundtrack AS 'Fond sonore',\n  w.notes AS 'Observations'\nFROM workouts w\nJOIN users u ON u.id = w.user_id\nLEFT JOIN (\n  SELECT ranked.user_id, ranked.d, ranked.measured_at, ranked.weight_kg, ranked.fat_mass_kg, ranked.fat_percentage, ranked.waist_cm, ranked.source_name\n  FROM (\n    SELECT\n      wm.user_id,\n      DATE(wm.measured_at) AS d,\n      wm.measured_at,\n      wm.weight_kg,\n      wm.fat_mass_kg,\n      wm.fat_percentage,\n      wm.waist_cm,\n      s.name AS source_name,\n      ROW_NUMBER() OVER (\n        PARTITION BY wm.user_id, DATE(wm.measured_at)\n        ORDER BY\n          CASE s.name\n            WHEN 'withings' THEN 1\n            WHEN 'healthtracker' THEN 2\n            ELSE 3\n          END,\n          wm.measured_at DESC,\n          wm.id DESC\n      ) AS rn\n    FROM weight_measurements wm\n    JOIN sources s ON s.id = wm.source_id\n  ) ranked\n  WHERE ranked.rn = 1\n) wm ON wm.user_id = w.user_id\n  AND DATE(w.start_time) = wm.d\nWHERE $__timeFilter(w.start_time)\n  AND w.deleted = 0\n  AND ('${user_id:raw}' = 'all' OR FIND_IN_SET(COALESCE(u.alias, u.name), '${user_id:csv}'))\nORDER BY w.start_time DESC",
          "refId": "A"
        }
      ],
      "title": "Entrainement velo elliptique",
      "type": "table"
    }
